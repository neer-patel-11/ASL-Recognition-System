name: ASL-Recognition-System

python_env: python_env.yaml   

entry_points:

  train:
    parameters:
      model:      {type: str,   default: "traditional_ml"}  # traditional_ml | mlp | cnn
      lr:         {type: float, default: 0.001}
      epochs:     {type: int,   default: 20}
      batch_size: {type: int,   default: 64}
    cmd: "python src/train.py --model {model}
            --lr {lr}
            --epochs {epochs}
            --batch_size {batch_size}"

  download:
    parameters:
      dest_dir: {type: str, default: "data/raw"}
    cmd: "python src/data/download.py --dest_dir {dest_dir}"

  validate:
    parameters:
      dataset_path: {type: str, default: "data/raw"}
    cmd: "python src/data/validate.py --dataset_path {dataset_path}"

  split:
    parameters:
      dataset_path: {type: str, default: "data/raw"}
    cmd: "python src/data/split.py --dataset_path {dataset_path}"

  full_pipeline:
    cmd: "dvc repro"   # MLflow launches DVC, DVC handles stage ordering