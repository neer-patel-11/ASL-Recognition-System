name: ASL-Recognition-System


entry_points:

  test:
    command: "echo hello"
    
  train:
    parameters:
      model: {type: str, default: "traditional_ml"}
    command: >
      python src/train.py
      --model {model}

  download:
    parameters:
      dest_dir: {type: str, default: "data/raw"}
    command: >
      python src/data/download.py --dest_dir {dest_dir}

  validate:
    parameters:
      dataset_path: {type: str, default: "data/raw"}
    command: >
      python src/data/validate.py --dataset_path {dataset_path}

  split:
    parameters:
      dataset_path: {type: str, default: "data/raw"}
    command: >
      python src/data/split.py --dataset_path {dataset_path}

  full_pipeline:
    command: "dvc repro"